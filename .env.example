# Copy this file to .env and adjust values for your local environment.
# The backend reads these via pydantic-settings (dotenv).

JOBS_DIR=./jobs
DB_PATH=./db/huddletag.db
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# AWS credentials — only needed for jobs with data_dir: s3://...
#
# Credential resolution order (boto3 standard):
#   1. These env vars (highest priority)
#   2. ~/.aws/credentials + ~/.aws/config (mounted into the container)
#   3. EC2 / ECS IAM role (automatic when running on AWS — no config needed)
#
# Leave blank or unset to fall through to the next method.
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=       # only needed for temporary/assumed-role credentials
# AWS_DEFAULT_REGION=
